{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role management",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A payment order to unlock a PDF download",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "contactEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "documentType": { "type": "string", "enum": ["resume", "cover_letter"] },
        "documentData": { "type": "object" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["ownerId", "status", "documentType", "createdAt"]
    },
    "Mail": {
      "title": "Mail",
      "description": "Queued emails for the Trigger Email extension",
      "type": "object",
      "properties": {
        "to": { "type": "array", "items": { "type": "string" } },
        "message": { "type": "object" }
      },
      "required": ["to", "message"]
    },
    "Presence": {
      "title": "Presence",
      "description": "Real-time user online status heartbeats",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "email": { "type": "string" },
        "lastSeen": { "type": "string" },
        "isAnonymous": { "type": "boolean" },
        "view": { "type": "string" }
      },
      "required": ["userId", "lastSeen"]
    },
    "Visitor": {
      "title": "Visitor",
      "description": "Unique visitor record for traffic analytics",
      "type": "object",
      "properties": {
        "visitorId": { "type": "string" },
        "firstSeen": { "type": "string" },
        "userAgent": { "type": "string" }
      },
      "required": ["visitorId", "firstSeen"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "User orders for PDF downloads"
    },
    "/mail/{mailId}": {
      "schema": { "$ref": "#/entities/Mail" },
      "description": "Outbox for Firebase Trigger Email extension"
    },
    "/presence/{userId}": {
      "schema": { "$ref": "#/entities/Presence" },
      "description": "User online heartbeats"
    },
    "/visitors/{visitorId}": {
      "schema": { "$ref": "#/entities/Visitor" },
      "description": "Unique visitor analytics"
    }
  }
}
