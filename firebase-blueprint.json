{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile with role management",
      "type": "object",
      "properties": {
        "email": { "type": "string" },
        "name": { "type": "string" },
        "role": { "type": "string", "enum": ["user", "admin"] },
        "createdAt": { "type": "string" }
      },
      "required": ["email", "role"]
    },
    "Order": {
      "title": "Order",
      "description": "A payment order to unlock a PDF download",
      "type": "object",
      "properties": {
        "ownerId": { "type": "string" },
        "contactEmail": { "type": "string" },
        "status": { "type": "string", "enum": ["pending", "approved", "rejected"] },
        "documentType": { "type": "string", "enum": ["resume", "cover_letter"] },
        "documentData": { "type": "object" },
        "createdAt": { "type": "string" },
        "updatedAt": { "type": "string" }
      },
      "required": ["ownerId", "status", "documentType", "createdAt"]
    },
    "Mail": {
      "title": "Mail",
      "description": "Queued emails for the Trigger Email extension",
      "type": "object",
      "properties": {
        "to": { "type": "array", "items": { "type": "string" } },
        "message": { "type": "object" }
      },
      "required": ["to", "message"]
    }
  },
  "firestore": {
    "/users/{userId}": {
      "schema": { "$ref": "#/entities/User" },
      "description": "User profiles"
    },
    "/orders/{orderId}": {
      "schema": { "$ref": "#/entities/Order" },
      "description": "User orders for PDF downloads"
    },
    "/mail/{mailId}": {
      "schema": { "$ref": "#/entities/Mail" },
      "description": "Outbox for Firebase Trigger Email extension"
    }
  }
}
